{
  "baseUrl": "http://localhost:11434",
  "apiKey": "",
  "keyvault": "kvGPSecrets",
  "agentLoop": {
    "maxTurns": 8,
    "toolCallTimeoutSeconds": 60,
    "requestTimeoutSeconds": 900
  },
  "logging": {
    "level": "debug",
    "format": "jsonl",
    "maxFileSizeMB": 10,
    "maxFiles": 5
  },
  "skills": {
    "selection": {
      "topK": 1,
      "minScore": 0.30,
      "fuzzyMatch": true
    },
    "resources": {
      "maxFileSizeKB": 64,
      "maxTotalSizeKB": 256
    }
  },
  "scriptExecution": {
    "enabled": true,
    "image": "python:3.11-slim",
    "executionTimeoutSeconds": 30,
    "environment": {},
    "resources": {
      "memoryLimit": "128m",
      "cpuLimit": 0.5
    }
  },
  "telemetry": {
    "SendTelemetry": true,
    "NewRelicTimeOut": 3
  }
}