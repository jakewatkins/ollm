[build-system]
requires = ["setuptools>=61.0", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "ollm"
version = "1.2.0"
description = "A command line tool that wraps Ollama HTTP endpoint with MCP servers and skills"
readme = "README.md"
authors = [
    {name = "ollm", email = "ollm@example.com"}
]
license = {text = "MIT"}
requires-python = ">=3.11"
classifiers = [
    "Development Status :: 3 - Alpha",
    "Intended Audience :: Developers",
    "License :: OSI Approved :: MIT License",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3.11",
    "Programming Language :: Python :: 3.12",
    "Programming Language :: Python :: 3.13",
    "Programming Language :: Python :: 3.14",
]
dependencies = [
    "httpx>=0.25.0",
    "pydantic>=2.0.0",
    "typer>=0.9.0",
    "pyyaml>=6.0",
    "rich>=13.0.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=7.0",
    "pytest-cov",
    "black",
    "isort",
    "mypy",
    "ruff",
]
full = [
    "docker>=6.0.0",
    "azure-keyvault-secrets>=4.8.0",
    "azure-identity>=1.15.0",
]

[project.scripts]
ollm = "ollm.__main__:main"

[project.urls]
Homepage = "https://github.com/example/ollm"
Repository = "https://github.com/example/ollm"
Documentation = "https://github.com/example/ollm#readme"

[tool.setuptools.packages.find]
where = ["src"]

[tool.setuptools.package-data]
ollm = ["data/*.json"]

[tool.black]
line-length = 88