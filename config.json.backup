{
  "baseUrl": "http://localhost:11434",
  "apiKey": "",
  "agentLoop": {
    "maxTurns": 8,
    "toolCallTimeoutSeconds": 60,
    "requestTimeoutSeconds": 300
  },
  "logging": {
    "level": "debug",
    "format": "jsonl",
    "maxFileSizeMB": 10,
    "maxFiles": 5
  },
  "skills": {
    "selection": {
      "topK": 1,
      "minScore": 0.35,
      "fuzzyMatch": true
    },
    "resources": {
      "maxFileSizeKB": 64,
      "maxTotalSizeKB": 256
    }
  },
  "scriptExecution": {
    "enabled": true,
    "image": "ollm-runner:latest",
    "executionTimeoutSeconds": 30,
    "environment": {},
    "resources": {
      "memoryLimit": "128m",
      "cpuLimit": 0.5
    }
  }
}